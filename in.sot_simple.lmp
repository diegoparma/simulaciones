# Simple skyrmion test with SOT
# Focus: verify SOT torque drives spin motion

units metal
dimension 3
atom_style spin
boundary p p p
atom_modify map array

# Create small lattice
lattice bcc 2.8665
region box block 0 8 0 8 0 2
create_box 1 box
create_atoms 1 box

mass 1 55.845

# Simple exchange interaction (no DMI for now, to avoid complexity)
pair_style spin/exchange 3.5
pair_coeff * * exchange 3.5 0.01593 0.06626915552 1.211

neighbor 0.1 bin
neigh_modify every 10 check yes delay 20

# Random spin initialization
set group all spin/random 42 2.2

# Magnetic field + anisotropy for stabilization
# WITHOUT SOT: use standard precession/spin
# fix 1 all precession/spin zeeman 0.0 0.0 0.0 1.0 anisotropy 5e-05 0.0 0.0 1.0

# WITH SOT: add damping-like torque that drives spins
# Polarization in z-direction means torque will affect xy-plane motion
fix 1 all precession/spin zeeman 0.0 0.0 0.0 1.0 anisotropy 5e-05 0.0 0.0 1.0 sot/dl 0.030 0.0 0.0 1.0

# Langevin thermalization
fix 2 all langevin/spin 0.05 0.1 21

# NVE spin integrator
fix 3 all nve/spin lattice moving

timestep 0.0001

compute out_mag all spin
variable magx equal c_out_mag[1]
variable magy equal c_out_mag[2]
variable magz equal c_out_mag[3]
variable emag equal c_out_mag[5]

thermo_style custom step time v_magx v_magy v_magz v_emag
thermo 100

compute outsp all property/atom spx spy spz sp fmx fmy fmz
dump 1 all custom 20 dump.spins.lammpstrj type x y z c_outsp[1] c_outsp[2] c_outsp[3]

# Short equilibration without SOT
fix 1 all precession/spin zeeman 0.0 0.0 0.0 1.0 anisotropy 5e-05 0.0 0.0 1.0
run 200

# Now activate SOT
fix 1 all precession/spin zeeman 0.0 0.0 0.0 1.0 anisotropy 5e-05 0.0 0.0 1.0 sot/dl 0.030 0.0 0.0 1.0
run 800
