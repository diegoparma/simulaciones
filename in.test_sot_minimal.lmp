# Ultra-minimal test for new SOT parsing
# No pair interactions, just test precession/spin with sot/dl and sot/fl

units metal
atom_style spin
boundary p p p

atom_modify map array

region box block 0.0 1.0 0.0 1.0 0.0 1.0
create_box 1 box
create_atoms 1 single 0.5 0.5 0.5

mass 1 55.845
set group all spin 1.0 0.0 0.0 2.2

neighbor 0.1 bin

# Test NEW precession/spin styles: sot/dl and sot/fl
# This should parse without error if implementation is correct
fix 1 all precession/spin sot/dl 0.02 1.0 0.0 0.0 sot/fl 0.005 1.0 0.0 0.0
fix 2 all langevin/spin 0.0 0.001 21
fix 3 all nve/spin lattice frozen

timestep 0.0001

compute out_mag all spin
variable emag equal c_out_mag[5]
variable tmag equal c_out_mag[6]

thermo_style custom step time v_tmag v_emag 
thermo 10

# Run short test - should execute without parse errors
run 20
